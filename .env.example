# Required: selects the active handler (stt_short, stt_long, tts)
MODE=

# Shared
DEVICE=cuda
HF_HOME=/runpod-volume/huggingface

# STT (stt_short and stt_long)
MODEL_SIZE=ivrit-ai/whisper-large-v3-turbo-ct2
COMPUTE_TYPE=int8_float16
HF_TOKEN=

# TTS
TTS_STEPS=8
TTS_SPEED=0.95
TTS_CFG_SCALE=4.0
TTS_VOICE=female1
